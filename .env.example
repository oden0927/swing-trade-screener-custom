# jquants Premium V2 認証情報
# このファイルをコピーして .env を作成し、APIキーを記入してください
#
# APIキーは jquants ダッシュボードから発行します:
# https://jpx-jquants.com/ja/dashboard
#
# 発行後、ダッシュボードに表示されている文字列を JQUANTS_API_KEY に貼り付け

JQUANTS_API_KEY=your-api-key-here

# データ取得期間（日足）
DAILY_LOOKBACK_YEARS=3

# データ取得期間（月足換算 = 日足からリサンプル）
MONTHLY_LOOKBACK_YEARS=10

# ユニバース絞り込み
# JPX400, NIKKEI225, BOTH のいずれか
UNIVERSE=BOTH

# 最低出来高（直近20日平均、株数）
MIN_AVG_VOLUME=500000

# 監視リスト最大数（本書8時限目の推奨に従い20以下）
MAX_WATCHLIST_SIZE=20
